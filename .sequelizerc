import path from "path";
import { fileURLToPath } from "url";

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

export const config = path.resolve(__dirname, "src/config/config.cjs");
export const modelsPath = path.resolve(__dirname, "src/models");
export const seedersPath = path.resolve(__dirname, "src/seeders");
export const migrationsPath = path.resolve(__dirname, "src/migrations");
