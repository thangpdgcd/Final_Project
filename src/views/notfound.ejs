<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="UTF-8" />
        <title>404 - Not Found</title>
        <style>
            body {
                margin: 0;
                padding: 0;
                font-family: Arial, sans-serif;
                background: linear-gradient(135deg, #667eea, #764ba2);
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #fff;
            }

            .container {
                text-align: center;
                background: rgba(0, 0, 0, 0.3);
                padding: 50px 70px;
                border-radius: 15px;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            }

            h1 {
                font-size: 100px;
                margin: 0;
            }

            h2 {
                margin: 10px 0 20px;
            }

            p {
                margin-bottom: 30px;
                opacity: 0.9;
            }

            a {
                text-decoration: none;
                background: #fff;
                color: #764ba2;
                padding: 12px 25px;
                border-radius: 30px;
                font-weight: bold;
                transition: 0.3s;
            }

            a:hover {
                background: #f1f1f1;
                transform: scale(1.05);
            }
        </style>
    </head>

    <body>
        <div class="container">
            <h1>404</h1>
            <h2>Page Not Found</h2>
            <p>Sorry, the page you are looking for does not exist.</p>
            <a href="/">Go Back Home</a>
        </div>
    </body>

</html>