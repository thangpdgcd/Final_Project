<!DOCTYPE html>
<html>
  <head>
    <title>Danh sách thanh toán</title>
    <meta charset="UTF-8" />
  </head>
  <body>
    <h1>Danh sách Thanh Toán</h1>
    <table border="1">
      <thead>
        <tr>
          <th>ID</th>
          <th>OrderItemId</th>
          <th>Phương thức</th>
          <th>Trạng thái</th>
          <th>Số tiền</th>
          <th>Đã thanh toán</th>
          <th>Mã giao dịch</th>
        </tr>
      </thead>
      <tbody>
        <% if (payments && payments.length > 0) { %> <%
        payments.forEach(function(payment) { %>
        <tr>
          <td><%= payment.paymentId %></td>
          <td><%= payment.orderItemId %></td>
          <td><%= payment.payments_method %></td>
          <td><%= payment.payments_status %></td>
          <td><%= payment.amount %></td>
          <td><%= payment.paid ? "Có" : "Không" %></td>
          <td><%= payment.transactionId %></td>
        </tr>
        <% }) %> <% } else { %>
        <tr>
          <td colspan="7">Không có dữ liệu thanh toán.</td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </body>
</html>
