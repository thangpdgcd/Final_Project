<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <% const isUpdate = typeof Categories !== 'undefined' && Categories; %>
    <title><%= isUpdate ? "Cập nhật danh mục" : "Thêm danh mục mới" %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="form-container">
      <h1><%= isUpdate ? "Cập nhật danh mục" : "Thêm danh mục mới" %></h1>

      <form
        action="<%= isUpdate ? `/categories/update/${Categories.Categories_ID}` : '/categories/create' %>"
        method="POST">
        <div class="form-group">
          <label for="Name">Tên danh mục:</label>
          <input
            type="text"
            id="Name"
            name="Name"
            value="<%= isUpdate ? Categories.Name : '' %>"
            required />
        </div>

        <div class="form-group">
          <label for="Description">Mô tả:</label>
          <textarea id="Description" name="Description" rows="3">
<%= isUpdate ? Categories.Description : '' %></textarea
          >
        </div>

        <button type="submit"><%= isUpdate ? "Cập nhật" : "Thêm mới" %></button>
      </form>

      <a href="/categories">⬅ Quay lại danh sách</a>
    </div>
  </body>
</html>
