<!DOCTYPE html>
<html>
  <head>
    <title>Đăng ký</title>
  </head>
  <body>
    <h2>Đăng ký</h2>
    <% if (message) { %>
    <p style="color: red"><%= message %></p>
    <% } %>
    <form action="/api/register" method="POST">
      <input type="text" name="Name" placeholder="Tên" required /><br />
      <input type="email" name="Email" placeholder="Email" required /><br />
      <input type="text" name="Address" placeholder="Địa chỉ" /><br />
      <input type="text" name="PhoneNumber" placeholder="Số điện thoại" /><br />
      <input
        type="password"
        name="password"
        placeholder="Mật khẩu"
        required /><br />
      <select name="roleID">
        <option value="1">Người dùng</option>
        <option value="2">Quản trị</option>
        <option value="3">Quản lý</option></select
      ><br />
      <button type="submit">Đăng ký</button>
    </form>
  </body>
</html>
