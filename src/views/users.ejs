<!DOCTYPE html>
<html>
  <head>
    <title>Danh sách người dùng</title>
  </head>
  <body>
    <h1>Danh sách người dùng</h1>

    <% if (users && users.length > 0) { %>
    <table border="1">
      <thead>
        <tr>
          <th>STT</th>
          <th>Tên</th>
          <th>Email</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach((user, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= user.Name %></td>
          <td><%= user.Email %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } else { %>
    <p>Không có người dùng nào.</p>
    <% } %>
  </body>
</html>
