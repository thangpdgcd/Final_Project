<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <title>Tài liệu API</title>
    <script
      type="module"
      src="https://unpkg.com/rapidoc/dist/rapidoc-min.js"></script>
    <style>
      body {
        margin: 0;
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f4f6f8;
      }
    </style>
  </head>
  <body>
    <rapi-doc
      spec-url="/openapi.json"
      theme="light"
      render-style="read"
      show-header="true"
      show-info="true"
      heading-text="Tài liệu API - Dự án cuối kỳ"
      primary-color="#1976d2"
      regular-font="Segoe UI, sans-serif"
      allow-authentication="true"
      allow-server-selection="true"
      allow-try="true">
    </rapi-doc>
  </body>
</html>
