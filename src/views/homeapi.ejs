<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Tài liệu API</title>
    <script
      type="module"
      src="https://unpkg.com/rapidoc/dist/rapidoc-min.js"></script>
  </head>
  <body>
    <rapi-doc
      spec-url="/openapi.json"
      theme="light"
      render-style="read"
      show-header="true"
      primary-color="#1976d2"
      allow-try="true"></rapi-doc>
  </body>
</html>
