    },
    "/api/add-to-cart": {
      "post": {
        "tags": ["Carts"],
        "summary": "Thêm sản phẩm vào giỏ hàng",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "userId": { "type": "integer" },
                  "productId": { "type": "integer" },
                  "quantity": { "type": "integer" },
                  "price": { "type": "number" }
                },
                "required": ["userId", "productId", "quantity", "price"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Thêm sản phẩm vào giỏ thành công" },
          "500": { "description": "Lỗi khi thêm sản phẩm" }
        }
      }
    },
